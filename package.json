{
  "name": "quicks-ark-bot-website",
  "version": "1.1.0",
  "private": true,
  "description": "Marketing website for Quick's ARK Bot — Premium Discord automation for ARK communities.",
  "scripts": {
    "build": "node build.mjs",
    "preview": "npx --yes serve dist -l 8080",
    "dev": "npx --yes serve . -l 8080",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.36.0",
    "wrangler": "^4.95.0"
  }
}
