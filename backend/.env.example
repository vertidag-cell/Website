# Quick's ARK Bot — Dashboard backend env vars
# Copy these into your Square Cloud project's secrets / .env.
# DO NOT commit real values to a public repo.

# Discord OAuth app (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match the redirect added in the Discord OAuth app:
#   https://YOUR_BACKEND_DOMAIN/auth/discord/callback
DISCORD_REDIRECT_URI=

# Session cookie signing (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
SESSION_SECRET=

# Frontend (Cloudflare Pages domain)
DASHBOARD_FRONTEND_URL=https://50bf9296.website-1h0.pages.dev
# CORS — must match the frontend's origin EXACTLY (no trailing slash)
DASHBOARD_ALLOWED_ORIGIN=https://50bf9296.website-1h0.pages.dev

# Run in production mode (enables secure cookies + sameSite=none)
NODE_ENV=production

# Optional: comma-separated Discord user IDs with full dashboard access
# even on guilds they aren't in
BOT_SUPER_ADMINS=
